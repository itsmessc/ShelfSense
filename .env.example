# Google Gemini API Key - required for AI categorization and forecasting
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# MySQL connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=shelfsense

# Backend server port (default: 3001)
PORT=3001

# Set to "true" to always use rule-based fallback (no AI calls, works offline)
USE_FALLBACK_ONLY=false
